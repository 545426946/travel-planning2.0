<!-- pages/register/register.wxml -->
<view class="container">
  <!-- йЎ¶йғЁиЈ…йҘ° -->
  <view class="header-decoration">
    <view class="decoration-circle circle-1"></view>
    <view class="decoration-circle circle-2"></view>
  </view>

  <!-- дё»иҰҒеҶ…е®№еҢәеҹҹ -->
  <view class="main-content">
    <!-- Logo е’Ңж Үйўҳ -->
    <view class="logo-section">
      <image class="logo" src="/pages/image/logo.png" mode="aspectFit" binderror="onImageError"></image>
      <text class="app-name">жіЁеҶҢиҙҰеҸ·</text>
      <text class="app-slogan">еҠ е…ҘжҲ‘д»¬пјҢејҖеҗҜзІҫеҪ©ж—…зЁӢ</text>
    </view>

    <!-- жіЁеҶҢиЎЁеҚ• -->
    <view class="register-form">
      <!-- з”ЁжҲ·еҗҚ -->
      <view class="form-group">
        <view class="input-wrapper {{formErrors.username ? 'error' : ''}}">
          <text class="input-icon">рҹ‘Ө</text>
          <input 
            class="form-input" 
            type="text" 
            placeholder="иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚ"
            value="{{formData.username}}"
            bindinput="onInput"
            data-field="username"
            maxlength="20"
          />
        </view>
        <text class="error-text" wx:if="{{formErrors.username}}">{{formErrors.username}}</text>
      </view>



      <!-- еҜҶз Ғ -->
      <view class="form-group">
        <view class="input-wrapper {{formErrors.password ? 'error' : ''}}">
          <text class="input-icon">рҹ”’</text>
          <input 
            class="form-input" 
            type="{{showPassword ? 'text' : 'password'}}" 
            placeholder="иҜ·иҫ“е…ҘеҜҶз Ғ"
            value="{{formData.password}}"
            bindinput="onInput"
            data-field="password"
            maxlength="50"
          />
          <text class="password-toggle" bindtap="togglePassword">
            {{showPassword ? 'рҹ‘ҒпёҸ' : 'рҹ‘ҒпёҸвҖҚрҹ—ЁпёҸ'}}
          </text>
        </view>
        <text class="error-text" wx:if="{{formErrors.password}}">{{formErrors.password}}</text>
      </view>

      <!-- зЎ®и®ӨеҜҶз Ғ -->
      <view class="form-group">
        <view class="input-wrapper {{formErrors.confirmPassword ? 'error' : ''}}">
          <text class="input-icon">рҹ”җ</text>
          <input 
            class="form-input" 
            type="{{showConfirmPassword ? 'text' : 'password'}}" 
            placeholder="иҜ·зЎ®и®ӨеҜҶз Ғ"
            value="{{formData.confirmPassword}}"
            bindinput="onInput"
            data-field="confirmPassword"
            maxlength="50"
          />
          <text class="password-toggle" bindtap="toggleConfirmPassword">
            {{showConfirmPassword ? 'рҹ‘ҒпёҸ' : 'рҹ‘ҒпёҸвҖҚрҹ—ЁпёҸ'}}
          </text>
        </view>
        <text class="error-text" wx:if="{{formErrors.confirmPassword}}">{{formErrors.confirmPassword}}</text>
      </view>

      <!-- еҚҸи®®еҗҢж„Ҹ -->
      <view class="agreement-section">
        <view class="agreement-row" bindtap="toggleAgree">
          <view class="checkbox {{agreeTerms ? 'checked' : ''}}">
            <text wx:if="{{agreeTerms}}">вң“</text>
          </view>
          <text class="agreement-text">жҲ‘е·Ійҳ…иҜ»е№¶еҗҢж„Ҹ</text>
        </view>
        <view class="agreement-links">
          <text class="link-text" bindtap="viewUserAgreement">гҖҠз”ЁжҲ·еҚҸи®®гҖӢ</text>
          <text>е’Ң</text>
          <text class="link-text" bindtap="viewPrivacyPolicy">гҖҠйҡҗз§Ғж”ҝзӯ–гҖӢ</text>
        </view>
      </view>

      <!-- жіЁеҶҢжҢүй’® -->
      <button 
        class="register-btn" 
        bindtap="register"
        loading="{{isLoading}}"
        disabled="{{isLoading || !agreeTerms}}"
      >
        {{isLoading ? 'жіЁеҶҢдёӯ' : 'з«ӢеҚіжіЁеҶҢ'}}
      </button>

      <!-- зҷ»еҪ•й“ҫжҺҘ -->
      <view class="login-link">
        <text>е·ІжңүиҙҰеҸ·пјҹ</text>
        <text class="login-text" bindtap="goToLogin">з«ӢеҚізҷ»еҪ•</text>
      </view>
    </view>

    <!-- е…¶д»–жіЁеҶҢж–№ејҸ -->
    <view class="other-register">
      <view class="divider">
        <text class="divider-line"></text>
        <text class="divider-text">е…¶д»–жіЁеҶҢж–№ејҸ</text>
        <text class="divider-line"></text>
      </view>
      
      <view class="other-register-options">
        <view class="other-register-item">
          <text class="other-register-icon">рҹҹў</text>
          <text class="other-register-text">еҫ®дҝЎжіЁеҶҢ</text>
        </view>
      </view>
    </view>
  </view>

  <!-- еә•йғЁиЈ…йҘ° -->
  <view class="footer-decoration">
    <text class="footer-text">В© 2024 ж—…иЎҢи§„еҲ’ - и®©ж—…иЎҢжӣҙзҫҺеҘҪ</text>
  </view>
</view>
